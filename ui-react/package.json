{
    "name": "glancier-ui",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:backend": "python ../scripts/dev_server.py",
        "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev\"",
        "tauri": "tauri",
        "tauri:dev": "tauri dev",
        "tauri:dev:all": "concurrently -n backend,tauri -c blue,yellow \"npm run dev:backend\" \"npm run tauri:dev\"",
        "tauri:build": "bash ../scripts/build.sh",
        "tauri:build:mac": "bash ../scripts/build.sh --platform mac",
        "tauri:build:win": "bash ../scripts/build.sh --platform win",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "test": "vitest",
        "audit:high": "npm audit --audit-level=high",
        "test:core": "vitest run src/api/client.test.ts src/store/index.test.ts src/components/widgets/WidgetRenderer.test.tsx src/components/ui/MetricCard.test.tsx src/components/ui/BentoWidget.test.tsx src/pages/Integrations.test.tsx src/pages/dashboardLayout.test.ts",
        "typecheck": "tsc --noEmit -p tsconfig.app.json"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.5",
        "@radix-ui/react-progress": "^1.1.1",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.1",
        "@radix-ui/react-slot": "^1.1.1",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-tooltip": "^1.1.5",
        "@tauri-apps/api": "~2.10.0",
        "@tauri-apps/plugin-shell": "^2.3.5",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "gridstack": "^12.4.2",
        "lucide-react": "^0.468.0",
        "monaco-editor": "^0.52.2",
        "monaco-yaml": "^5.4.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-grid-layout": "^2.2.2",
        "react-resizable": "^3.1.3",
        "react-router-dom": "^7.13.0",
        "recharts": "^2.15.0",
        "swr": "^2.4.1",
        "tailwind-merge": "^2.6.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.10.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@types/node": "^22.10.0",
        "@types/react": "^18.3.18",
        "@types/react-dom": "^18.3.5",
        "@types/react-grid-layout": "^1.3.6",
        "@types/react-resizable": "^3.0.8",
        "@vitejs/plugin-react": "^4.3.4",
        "autoprefixer": "^10.4.20",
        "concurrently": "^9.2.1",
        "jsdom": "^27.1.0",
        "playwright": "^1.58.2",
        "postcss": "^8.4.49",
        "tailwindcss": "^3.4.17",
        "typescript": "^5.7.3",
        "vite": "^6.0.11",
        "vitest": "^4.0.0"
    }
}
