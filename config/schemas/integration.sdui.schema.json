                        "default": "auto",
                        "anyOf": [
                          {
                            "type": "string",
                            "const": "auto"
                          },
                          {
                            "type": "string",
                            "const": "stretch"
                          },
                          {
                            "type": "number",
                            "exclusiveMinimum": 0
                          }
                        ]
                      },
