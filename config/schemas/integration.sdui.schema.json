              "$ref": "#/$defs/templatedString"
            }
          ]
        },
        "item_alias": {
          "type": "string"
        },
        "render": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/Widget"
              }
