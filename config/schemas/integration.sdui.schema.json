{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Glanceus React SDUI Fragment",
  "description": "Generated from React SDUI zod schemas.",
  "$defs": {
    "templatedString": {
      "type": "string",
      "pattern": "^\\{.*\\}$"
    },
    "spacingValue": {
      "type": "string",
      "enum": [
        "none",
        "sm",
        "md",
        "lg"
      ]
    },
    "sizeValue": {
      "type": "string",
      "enum": [
        "sm",
        "md",
        "lg",
        "xl"
      ]
    },
    "toneValue": {
      "type": "string",
      "enum": [
        "default",
        "muted",
        "info",
        "success",
        "warning",
        "danger"
      ]
    },
    "alignValue": {
      "type": "string",
      "enum": [
        "start",
        "center",
        "end"
      ]
    },
    "Container": {
      "type": "object",
      "properties": {
        "type": {
          "anyOf": [
            {
              "type": "string",
              "const": "Container"
            },
            {
              "$ref": "#/$defs/templatedString"
            }
          ]
        },
        "items": {
          "anyOf": [
            {
              "type": "array",
              "items": {
