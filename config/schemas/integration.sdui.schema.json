          ]
        },
        "align_y": {
          "anyOf": [
            {
              "$ref": "#/$defs/alignValue",
              "default": "start"
            },
            {
              "$ref": "#/$defs/templatedString"
            }
          ]
        }
      },
      "required": [
        "type",
        "items"
      ],
      "additionalProperties": false
    },
    "ColumnSet": {
      "type": "object",
      "properties": {
        "type": {
          "anyOf": [
            {
              "type": "string",
              "const": "ColumnSet"
